# ─────────────────────────────────────────────────────────────
#  SLS Estimator — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Google Apps Script Web App URL ──
# How to get this:
#   1. Open your GAS project at https://script.google.com
#   2. Paste the contents of Code_nextjs_bridge.gs into Code.gs (at the bottom)
#   3. Click Deploy → Manage deployments → New version → Deploy
#   4. Copy the Web App URL (looks like: https://script.google.com/macros/s/ABC.../exec)
#   5. Paste it here (for local dev)

GAS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ── Vercel Deployment ──
# When deploying to Vercel, set the above variable in the Vercel Dashboard:
#   1. Go to https://vercel.com → Your Project → Settings → Environment Variables
#   2. Add: Name = GAS_WEBAPP_URL, Value = your GAS web app URL
#   3. Redeploy for changes to take effect
