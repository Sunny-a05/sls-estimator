{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Next.js Production Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "GAS Compiled (Static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "8080", "-s"],
      "port": 8080
    }
  ]
}
